# AWS deployment env file template.
# Copy to .env.aws on EC2 and replace placeholder values.

# RDS
CONNSTR_RDS=Host=<rds-endpoint>;Port=5432;Database=<db-name>;Username=<db-user>;Password=<db-password>

# JWT
JWT_KEY=<strong-random-secret>
JWT_ISSUER=aihealth.aws
JWT_AUDIENCE=aihealth.aws

# AWS service config (S3 + SQS already running)
AWS_REGION=us-east-2
S3_BUCKET=<your-bucket-name>
SQS_QUEUE_URL=https://sqs.<region>.amazonaws.com/<account-id>/<queue-name>
CORS_ALLOWED_ORIGINS=http://<s3-website-endpoint>

# Optional LLM config
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=45

# Worker tuning
OCR_POLL_WAIT_SECONDS=20
OCR_LOOP_SLEEP_SECONDS=2
